# Copy to .env and edit. The app reads .env from the working directory.

# Required: long random string. Used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Bootstrap admin user — created automatically on first start if users table is empty.
# Remove or leave blank after first run; subsequent admins are created via the admin page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Listen port (default 3000). Behind nginx on Linode, this stays internal.
PORT=3000

# Public origin used for CORS / cookies (e.g. https://chat.example.com).
# Leave blank to allow same-origin only (recommended when behind nginx).
PUBLIC_ORIGIN=

# Directory for SQLite DB and uploaded files (default ./data).
# In production, set this to /var/lib/blatchat
DATA_DIR=./data

# Trust X-Forwarded-* from nginx (set to 1 behind a reverse proxy)
TRUST_PROXY=0
